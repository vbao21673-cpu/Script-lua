-- 3. LOGIC CÁC NÚT BẤM
-- ==========================================
local isSpeedEnabled = false
local loopConnection = nil
local function enforceSpeed()
	local character = player.Character
	if character then
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			if isSpeedEnabled then
				local inputSpeed = tonumber(SpeedInput.Text) or 16
				humanoid.WalkSpeed = math.clamp(inputSpeed, 0, 200)
			else
				humanoid.WalkSpeed = 16
			end
		end
	end
end

ToggleSpeedBtn.MouseButton1Click:Connect(function()
	isSpeedEnabled = not isSpeedEnabled
	if isSpeedEnabled then
		ToggleSpeedBtn.Text = "TỐC ĐỘ: ĐANG BẬT"
		ToggleSpeedBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
		ToggleSpeedBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
		if not loopConnection then loopConnection = RunService.Heartbeat:Connect(enforceSpeed) end
	else
		ToggleSpeedBtn.Text = "TỐC ĐỘ: TẮT"
		ToggleSpeedBtn.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
		ToggleSpeedBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		if loopConnection then loopConnection:Disconnect(); loopConnection = nil end
		enforceSpeed() 
	end
end)

