-- LOGIC HEARTBEAT TỔNG HỢP
RunService.Heartbeat:Connect(function()
	-- 1. Xử lý Fling (Neo vị trí bạn + Đẩy đối thủ)
	if isFlingEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
		local myHrp = player.Character.HumanoidRootPart
		-- Neo vị trí (Không bị văng)
		myHrp.CFrame = myHrp.CFrame
		myHrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		-- Xuyên thấu
		for _, child in pairs(player.Character:GetChildren()) do if child:IsA("BasePart") then child.CanCollide = false end end
		-- Chạm là bay
		for _, oP in pairs(Players:GetPlayers()) do
			if oP ~= player and oP.Character and oP.Character:FindFirstChild("HumanoidRootPart") then
				local otherHrp = oP.Character.HumanoidRootPart
				if (myHrp.Position - otherHrp.Position).Magnitude < 5 then
					otherHrp.AssemblyLinearVelocity = Vector3.new(math.random(-500, 500), 1000, math.random(-500, 500))
					otherHrp.CFrame = otherHrp.CFrame + Vector3.new(math.random(-50, 50), 1000, math.random(-50, 50))
				end
			end
		end
	end
end)

